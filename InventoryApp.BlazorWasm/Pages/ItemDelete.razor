@page "/items/delete/{id}"
@inject HttpClient HttpClient
@inject NavigationManager NavigationManager

<h3>Delete Item</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<h4>Confirm that you want to delete this item.</h4>

@if (item != null)
{
    <dl class="row">
        <dt class="col-sm-2">
            Product Code
        </dt>
        <dd class="col-sm-10">
            @item.ProductCode
        </dd>
        <dt class="col-sm-2">
            Name
        </dt>
        <dd class="col-sm-10">
            @item.Name
        </dd>
        <dt class="col-sm-2">
            Quantity
        </dt>
        <dd class="col-sm-10">
            @item.Quantity.ToString("#,##0")
        </dd>
    </dl>
    <div class="mb-3">
        <button type="submit" class="btn btn-danger" @onclick="DeleteItem">Delete</button>
        <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
    </div>
}

@code {
    [Parameter]
    public string id { get; set; } = string.Empty;

    private InventoryItem? item = null;
    private string? errorMessage = null;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null; // Reset error message before loading
        // Parse the string parameter into an integer ID
        if (!int.TryParse(id, out int itemId))
        {
            errorMessage = "Invalid item ID.";
            return;
        }
        InventoryItemDetailsRequest request = new InventoryItemDetailsRequest { Id = itemId };
        var response = await HttpClient.PostAsJsonAsync("api/items/details", request);
        if (response.IsSuccessStatusCode)
        {
            var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<InventoryItem>>();
            if (apiResponse?.IsSuccessful == true)
            {
                item = apiResponse.Response;
            }
            else
            {
                errorMessage = "Failed to load item details.";
            }
        }
        else
        {
            errorMessage = "Failed to load item details.";
        }
    }

    private async Task DeleteItem()
    {
        errorMessage = null; // Reset error message before loading
        var response = await HttpClient.PostAsJsonAsync("api/items/delete", item);
        if (response.IsSuccessStatusCode)
        {
            var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse>();
            if (apiResponse?.IsSuccessful == true)
            {
                NavigationManager.NavigateTo($"/items");
                return;
            }
            else
            {
                errorMessage = "Failed to delete the item.";
            }
        }
        else
        {
            errorMessage = "Failed to delete the item.";
        }
    }

    private void CancelDelete()
    {
        NavigationManager.NavigateTo($"/items");
    }
}
