@page "/items/edit/{id}"
@inject HttpClient HttpClient
@inject NavigationManager NavigationManager

<h3>Edit Item</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

@if (item != null)
{
    <EditForm Model="item" OnValidSubmit="UpdateItem">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label" for="productCode">Product Code</label>
            <InputText id="productCode" class="form-control" @bind-Value="item.ProductCode" />
            <ValidationMessage For="@(() => item.ProductCode)" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="name">Name</label>
            <InputText id="name" class="form-control" @bind-Value="item.Name" />
            <ValidationMessage For="@(() => item.ProductCode)" />
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Save</button>
            <button type="button" class="btn btn-secondary" @onclick="CancelUpdate">Cancel</button>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public string id { get; set; } = string.Empty;

    private InventoryItem? item = null;
    private string? errorMessage = null;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null; // Reset error message before loading
        // Parse the string parameter into an integer ID
        if (!int.TryParse(id, out int itemId))
        {
            errorMessage = "Invalid item ID.";
            return;
        }
        InventoryItemDetailsRequest request = new InventoryItemDetailsRequest { Id = itemId };
        var response = await HttpClient.PostAsJsonAsync("api/items/details", request);
        if (response.IsSuccessStatusCode)
        {
            var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse<InventoryItem>>();
            if (apiResponse?.IsSuccessful == true)
            {
                item = apiResponse.Response;
            }
            else
            {
                errorMessage = "Failed to load item details.";
            }
        }
        else
        {
            errorMessage = "Failed to load item details.";
        }
    }

    private async Task UpdateItem()
    {
        errorMessage = null; // Reset error message before loading
        var response = await HttpClient.PostAsJsonAsync("api/items/update", item);
        if (response.IsSuccessStatusCode)
        {
            var apiResponse = await response.Content.ReadFromJsonAsync<ApiResponse>();
            if (apiResponse?.IsSuccessful == true)
            {
                NavigationManager.NavigateTo($"/items");
                return;
            }
            else
            {
                errorMessage = "Failed to update the item.";
            }
        }
        else
        {
            errorMessage = "Failed to update the item.";
        }
    }

    private void CancelUpdate()
    {
        NavigationManager.NavigateTo($"/items");
    }
}
